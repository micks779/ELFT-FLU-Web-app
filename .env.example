# NextAuth
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# ─── Database ────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — SQLite (no setup required)
DATABASE_URL="file:./prisma/dev.db"

# PRODUCTION — Azure SQL (Data Warehouse provided by ELFT Data Team)
# Replace <server>, <database>, <user>, <password> with values from the ELFT data team.
# Format: sqlserver://<server>.database.windows.net:1433;database=<database>;user=<user>;password=<password>;encrypt=true;trustServerCertificate=false
# DATABASE_URL="sqlserver://elft-sql.database.windows.net:1433;database=flu-vaccination;user=flu-app;password=YOURPASSWORD;encrypt=true;trustServerCertificate=false"

# App URL — must match the Azure App Registration redirect URI
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_URL=https://flu.elft.nhs.uk
